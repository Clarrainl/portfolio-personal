---
import { getLangFromPath } from '../../lib/i18n.js';

const currentYear = new Date().getFullYear();
const lang = getLangFromPath(Astro.url.pathname);

const contactHref = lang === 'en' ? '/en/contact' : '/contacto';
const contactLabel = lang === 'en' ? 'Contact' : 'Contacto';

const socialLinks = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/carlos-larrain-lihn-298199208/' },
  { label: 'Instagram', href: 'https://www.instagram.com/carlos_larrainl/' },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)] mt-24">
  <div class="py-12" style="padding-left: 3rem; padding-right: 3rem;">
    <div class="flex items-center justify-between">
      <!-- Name & Year -->
      <div>
        <p class="font-display text-lg font-light tracking-widest uppercase">Portfolio</p>
        <p class="text-sm text-[var(--color-text-secondary)] mt-1">© {currentYear}</p>
      </div>

      <!-- Links — right aligned -->
      <div class="flex items-center gap-8">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <a
          href={contactHref}
          class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors duration-200"
        >
          {contactLabel}
        </a>
      </div>
    </div>
  </div>
</footer>
