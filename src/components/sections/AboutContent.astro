---
import { urlFor } from '../../lib/sanity.js';
import type { About } from '../../types/index.js';
import { PortableText } from '@portabletext/react';

interface Props {
  about: About;
}

const { about } = Astro.props;

const photoUrl = about.photo
  ? urlFor(about.photo).width(800).height(1000).fit('crop').url()
  : null;
---

<!-- Bio Section -->
<section class="max-w-[1280px] mx-auto px-6 lg:px-12 py-16 fade-in-section">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
    <!-- Photo -->
    <div class="relative order-2 lg:order-1">
      <div class="aspect-[3/4] overflow-hidden bg-[var(--color-surface)] border border-[var(--color-border)]">
        {photoUrl ? (
          <img
            src={photoUrl}
            alt={about.photo?.alt || 'Foto profesional'}
            class="w-full h-full object-cover"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center">
            <p class="text-sm text-[var(--color-text-secondary)]">Foto profesional</p>
          </div>
        )}
      </div>
      <div class="absolute -left-4 top-8 bottom-8 w-px bg-[var(--color-accent)]"></div>
    </div>

    <!-- Bio text -->
    <div class="order-1 lg:order-2">
      <p class="text-xs text-[var(--color-text-secondary)] tracking-[0.3em] uppercase mb-4">Sobre mí</p>
      {about.bio && about.bio.length > 0 ? (
        <div class="prose-about">
          <PortableText value={about.bio} />
        </div>
      ) : (
        <p class="text-[var(--color-text-secondary)]">Biografía pendiente de completar en Sanity.</p>
      )}

      {about.socialLinks && about.socialLinks.length > 0 && (
        <div class="flex flex-wrap gap-4 mt-8">
          {about.socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium border-b border-[var(--color-border)] pb-0.5 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors duration-200"
            >
              {link.platform}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<!-- Education Timeline -->
{about.education && about.education.length > 0 && (
  <section class="max-w-[1280px] mx-auto px-6 lg:px-12 py-16 border-t border-[var(--color-border)] fade-in-section">
    <p class="text-xs text-[var(--color-text-secondary)] tracking-[0.3em] uppercase mb-12">Formación</p>

    <div class="relative pl-8 border-l border-[var(--color-border)]">
      {about.education.map((item, i) => (
        <div class:list={['relative pb-12', i === about.education.length - 1 ? 'pb-0' : '']}>
          <!-- Dot -->
          <div class="absolute -left-[1.35rem] top-1 w-2.5 h-2.5 bg-[var(--color-accent)]"></div>

          <span class="text-xs text-[var(--color-text-secondary)] tracking-wider">{item.year}</span>
          <h3 class="font-display text-2xl font-light mt-1 mb-1">{item.degree}</h3>
          <p class="text-sm font-medium text-[var(--color-text-secondary)]">{item.institution}</p>
          {item.description && (
            <p class="text-sm text-[var(--color-text-secondary)] mt-2 leading-relaxed max-w-2xl">
              {item.description}
            </p>
          )}
        </div>
      ))}
    </div>
  </section>
)}

<!-- Skills -->
{about.skills && about.skills.length > 0 && (
  <section class="max-w-[1280px] mx-auto px-6 lg:px-12 py-16 border-t border-[var(--color-border)] fade-in-section">
    <p class="text-xs text-[var(--color-text-secondary)] tracking-[0.3em] uppercase mb-8">Herramientas & Habilidades</p>
    <div class="flex flex-wrap gap-2">
      {about.skills.map((skill) => (
        <span class="text-sm px-4 py-2 border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] hover:text-[var(--color-text)] transition-colors duration-200">
          {skill}
        </span>
      ))}
    </div>
  </section>
)}

<style>
  .prose-about :global(h2) {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }
  .prose-about :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }
  .prose-about :global(strong) {
    color: var(--color-text);
    font-weight: 500;
  }
</style>
