---
import VideoBackground from '../ui/VideoBackground.astro';
import type { Lang } from '../../types/index.js';

interface Props {
  name?: string;
  tagline?: string;
  ctaText?: string;
  ctaHref?: string;
  lang?: Lang;
}

const {
  name = 'PORTAFOLIO',
  tagline = 'Arquitectura · Robótica · Impresión 3D',
  ctaText = 'Ver Proyectos',
  ctaHref = '/proyectos',
  lang = 'es',
} = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <VideoBackground mp4="/hero.mp4" />

  <!-- Portafolio + Name stacked, scrolls with hero -->
  <div
    class="absolute hidden md:flex flex-col items-center gap-1"
    style="top: 5rem; left: 50%; transform: translateX(-50%); white-space: nowrap; z-index: 40;"
  >
    <span class="font-display text-xl font-light tracking-widest text-white drop-shadow-sm">
      {name}
    </span>
    <a
      href={lang === 'es' ? '/' : '/en'}
      class="font-display text-xl font-light tracking-widest text-white/70 no-underline drop-shadow-sm"
    >
      Charlie Larraín L.
    </a>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-white/40">
    <a
      href={ctaHref}
      class="inline-block rounded-full border border-white/15 bg-black/30 backdrop-blur-xl text-white/80 text-sm font-medium tracking-wide transition-colors duration-200 hover:text-white"
      style="padding: 0.85rem 2rem;"
    >
      {ctaText}
    </a>
    <p class="text-xs font-medium tracking-[0.2em] uppercase text-white/60">{tagline}</p>
    <span class="text-xs tracking-wider uppercase text-center px-4">{lang === 'en' ? 'Scroll to know more' : 'Scroll para saber más'}</span>
    <div class="w-px h-12 bg-white/20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full bg-white/60 h-1/2 animate-[scroll-line_2s_ease-in-out_infinite]"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
</style>
