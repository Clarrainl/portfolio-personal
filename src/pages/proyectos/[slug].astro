---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import MediaGallery from '../../components/ui/MediaGallery.tsx';
import { getProjects, getProjectBySlug, urlFor } from '../../lib/sanity.js';
import { PortableText } from '@portabletext/react';
import { portableTextComponents } from '../../components/ui/PortableTextComponents.tsx';
import type { Project } from '../../types/index.js';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project, index) => ({
    params: { slug: project.slug.current },
    props: {
      prevProject: index > 0
        ? { title: projects[index - 1].title, slug: projects[index - 1].slug.current }
        : null,
      nextProject: index < projects.length - 1
        ? { title: projects[index + 1].title, slug: projects[index + 1].slug.current }
        : null,
    },
  }));
}

const { slug } = Astro.params;
const { prevProject, nextProject } = Astro.props as {
  prevProject: { title: string; slug: string } | null;
  nextProject: { title: string; slug: string } | null;
};
const project = await getProjectBySlug(slug!);

if (!project) {
  return Astro.redirect('/404');
}

const ogImage = project.coverImage
  ? urlFor(project.coverImage).width(1200).height(630).fit('crop').url()
  : undefined;

const coverImageUrl = project.coverImage
  ? urlFor(project.coverImage).width(1920).height(1080).fit('crop').url()
  : null;

const hasHero = project.heroVideo?.asset?.url || coverImageUrl;
---

<BaseLayout
  title={project.title}
  description={project.shortDescription}
  ogImage={ogImage}
>
  <!-- ── HERO: pantalla completa ── -->
  {hasHero && (
    <div class="relative w-full overflow-hidden" style="height: 100svh;">
      {project.heroVideo?.asset?.url ? (
        <video
          src={project.heroVideo.asset.url}
          autoplay
          muted
          loop
          playsinline
          class="w-full h-full object-cover"
        />
      ) : coverImageUrl ? (
        <img
          src={coverImageUrl}
          alt={project.coverImage?.alt || project.title}
          class="w-full h-full object-cover"
        />
      ) : null}

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-0 right-0 flex flex-col items-center gap-2 scroll-indicator">
        <svg width="48" height="48" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="chevron">
          <path d="M4 7l6 6 6-6" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="font-sans text-xs tracking-[0.3em] uppercase text-white">scroll</span>
      </div>
    </div>
  )}

  <!-- ── CUERPO DEL PROYECTO ── -->
  <div class="px-6 lg:px-12" style="padding-top: 6rem; padding-bottom: 4rem;">
    <div style="width: 80%; margin: 0 auto;">

      <!-- Título h1 -->
      <h1 class="font-display text-5xl md:text-6xl font-light leading-tight mb-12">{project.title}</h1>

      <!-- Descripción (portable text) -->
      {project.description && project.description.length > 0 && (
        <div class="prose-project mb-16">
          <PortableText value={project.description} components={portableTextComponents} />
        </div>
      )}

      <!-- Bloque de información del proyecto -->
      {(project.authors?.length || project.course || project.institution || project.year || project.moreInfoUrl) && (
        <div class="border-t border-[var(--color-border)] pt-10 mt-10">
          <h3 class="font-sans text-xs tracking-widest uppercase text-[var(--color-text-secondary)] mb-8">Información del proyecto</h3>
          <ul class="space-y-4">
            {project.authors && project.authors.length > 0 && (
              <li class="font-sans text-sm">
                <span class="font-semibold">Autores</span>
                <span class="text-[var(--color-text-secondary)] ml-3">{project.authors.join(', ')}</span>
              </li>
            )}
            {project.course && (
              <li class="font-sans text-sm">
                <span class="font-semibold">Curso</span>
                <span class="text-[var(--color-text-secondary)] ml-3">{project.course}</span>
              </li>
            )}
            {project.institution && (
              <li class="font-sans text-sm">
                <span class="font-semibold">Institución</span>
                <span class="text-[var(--color-text-secondary)] ml-3">{project.institution}</span>
              </li>
            )}
            <li class="font-sans text-sm">
              <span class="font-semibold">Año</span>
              <span class="text-[var(--color-text-secondary)] ml-3">{project.year}</span>
            </li>
          </ul>
          {project.moreInfoUrl && (
            <a
              href={project.moreInfoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-8 font-sans text-xs tracking-widest uppercase border-b border-[var(--color-text)] pb-0.5 hover:text-[var(--color-text-secondary)] hover:border-[var(--color-text-secondary)] transition-colors duration-200"
            >
              Más información →
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- ── IMÁGENES ── -->
  {project.gallery && project.gallery.length > 0 && (
    <div class="px-6 lg:px-12" style="padding-bottom: 6rem;">
      <div style="width: 80%; margin: 0 auto;">
        <h2 class="font-display text-3xl font-light mb-10">Imágenes</h2>
        <MediaGallery items={project.gallery} client:load />
      </div>
    </div>
  )}

  <!-- ── NAVEGACIÓN ENTRE PROYECTOS ── -->
  <div class="border-t border-[var(--color-border)] px-6 lg:px-12 py-12">
    <div style="width: 80%; margin: 0 auto;">
      <div class="flex items-center justify-between gap-4">
        {prevProject ? (
          <a
            href={`/proyectos/${prevProject.slug}`}
            class="font-sans text-xs tracking-widest uppercase rounded-full border border-[var(--color-border)] px-6 py-2.5 text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:border-[var(--color-text)] transition-all duration-200"
          >
            ← {prevProject.title}
          </a>
        ) : <span />}

        {nextProject ? (
          <a
            href={`/proyectos/${nextProject.slug}`}
            class="font-sans text-xs tracking-widest uppercase rounded-full border border-[var(--color-border)] px-6 py-2.5 text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:border-[var(--color-text)] transition-all duration-200"
          >
            {nextProject.title} →
          </a>
        ) : <span />}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes bounce-down {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .scroll-indicator {
    opacity: 1;
  }

  .chevron {
    animation: bounce-down 1.8s ease-in-out infinite;
  }

  .prose-project :global(p) {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.85;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }
  .prose-project :global(h2) {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-project :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-project :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }
  .prose-project :global(img) {
    width: 100%;
    margin: 2rem 0;
  }
</style>
