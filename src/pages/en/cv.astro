---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import CVContent from '../../components/sections/CVContent.astro';
import { getCV } from '../../lib/sanity.js';

const cv = await getCV();
---

<BaseLayout
  title="CV"
  description="Curriculum Vitae — Architect, Robotics, 3D Printing."
>
  <div class="pt-24">
    <div class="px-6 lg:px-12 text-center md:pt-20" style="padding-top: 7rem; padding-bottom: 2rem;">
      <h1 class="font-sans font-light uppercase tracking-widest text-6xl">CV</h1>
      <div style="height: 1px; background: #555; margin: 2.5rem auto 0; width: 80%;"></div>
    </div>

    {cv ? (
      <CVContent cv={cv} lang="en" />
    ) : (
      <div class="px-6 lg:px-12 py-24 text-center">
        <p class="text-[var(--color-text-secondary)]">CV not available yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
