---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import MediaGallery from '../../../components/ui/MediaGallery.tsx';
import { getProjects, getProjectBySlug, urlFor } from '../../../lib/sanity.js';
import { t } from '../../../lib/i18n.js';
import { PortableText } from '@portabletext/react';

const lang = 'en';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((p) => ({ params: { slug: p.slug.current } }));
}

const { slug } = Astro.params;
const project = await getProjectBySlug(slug!);
if (!project) return Astro.redirect('/en');

const categoryLabels: Record<string, string> = {
  arquitectura: t(lang, 'filter.arquitectura'),
  robotica: t(lang, 'filter.robotica'),
  impresion3d: t(lang, 'filter.impresion3d'),
};

const title = project.titleEn || project.title;
const shortDesc = project.shortDescriptionEn || project.shortDescription;
const description = project.descriptionEn || project.description;

const ogImage = project.coverImage ? urlFor(project.coverImage).width(1200).height(630).fit('crop').url() : undefined;
---

<BaseLayout title={title} description={shortDesc} ogImage={ogImage}>
  <div class="pt-16">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-12 py-16 border-b border-[var(--color-border)]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs text-[var(--color-text-secondary)] tracking-[0.3em] uppercase">{categoryLabels[project.category] || project.category}</span>
        <span class="w-px h-3 bg-[var(--color-border)]"></span>
        <span class="text-xs text-[var(--color-text-secondary)]">{project.year}</span>
      </div>
      <h1 class="font-display text-5xl md:text-7xl font-light leading-none">{title}</h1>
    </div>

    {project.coverImage && (
      <div class="max-w-[1280px] mx-auto px-6 lg:px-12 pt-12">
        <div class="aspect-[16/9] overflow-hidden">
          <img src={urlFor(project.coverImage).width(1280).height(720).fit('crop').url()} alt={project.coverImage.alt || title} class="w-full h-full object-cover" />
        </div>
      </div>
    )}

    {project.gallery && project.gallery.length > 0 && (
      <div class="max-w-[1280px] mx-auto px-6 lg:px-12 py-12">
        <MediaGallery items={project.gallery} client:load />
      </div>
    )}

    <div class="max-w-[1280px] mx-auto px-6 lg:px-12 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          {description && description.length > 0 && (
            <div class="prose prose-lg max-w-none">
              <PortableText value={description} />
            </div>
          )}
        </div>
        <div class="lg:col-span-1">
          <div class="border-t border-[var(--color-border)] pt-6 space-y-6">
            <div>
              <p class="text-xs text-[var(--color-text-secondary)] tracking-[0.2em] uppercase mb-2">Category</p>
              <p class="text-sm font-medium">{categoryLabels[project.category] || project.category}</p>
            </div>
            <div>
              <p class="text-xs text-[var(--color-text-secondary)] tracking-[0.2em] uppercase mb-2">Year</p>
              <p class="text-sm font-medium">{project.year}</p>
            </div>
            {project.tags && project.tags.length > 0 && (
              <div>
                <p class="text-xs text-[var(--color-text-secondary)] tracking-[0.2em] uppercase mb-3">Technologies</p>
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="text-xs px-3 py-1 border border-[var(--color-border)] text-[var(--color-text-secondary)]">{tag}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-[1280px] mx-auto px-6 lg:px-12 pb-16 border-t border-[var(--color-border)] pt-8">
      <a href="/en/projects" class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors duration-200">
        {t(lang, 'project.back')}
      </a>
    </div>
  </div>
</BaseLayout>
