---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import CategoryFilter from '../../../components/ui/CategoryFilter.tsx';
import { getProjects } from '../../../lib/sanity.js';
import { t } from '../../../lib/i18n.js';

const lang = 'en';
const projects = await getProjects();
---

<BaseLayout title="Projects" description="Full gallery of architecture, robotics and 3D printing projects.">
  <div class="pt-24">
    <div class="px-6 lg:px-12 text-center" style="padding-top: 5rem; padding-bottom: 4rem;">
      <h1 class="font-display text-6xl font-light">{t(lang, 'projects.title')}</h1>
      <div style="height: 1px; background: #555; margin: 2.5rem auto 0; width: 80%;"></div>
    </div>
    <div class="max-w-[1280px] mx-auto px-6 lg:px-12 py-16">
      <CategoryFilter projects={projects} lang={lang} client:load />
    </div>
  </div>
</BaseLayout>
