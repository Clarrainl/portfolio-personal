---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe."
>
  <div class="min-h-screen flex items-center justify-center px-6 pt-16">
    <div class="text-center">
      <p class="font-display text-[10rem] font-light leading-none text-[var(--color-border)] select-none">
        404
      </p>
      <h1 class="font-display text-3xl font-light mb-4 -mt-4">Página no encontrada</h1>
      <p class="text-[var(--color-text-secondary)] mb-10">
        La página que buscas no existe o fue movida.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-block bg-[var(--color-text)] text-white text-sm font-medium tracking-[0.2em] uppercase px-8 py-3 hover:bg-[var(--color-accent-dark)] transition-colors duration-200"
        >
          Ir al inicio
        </a>
        <a
          href="/proyectos"
          class="inline-block border border-[var(--color-border)] text-sm font-medium tracking-wide px-8 py-3 hover:bg-[var(--color-surface)] transition-colors duration-200"
        >
          Ver proyectos
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
